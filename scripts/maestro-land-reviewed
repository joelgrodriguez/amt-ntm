#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage: scripts/maestro-land-reviewed [--dry-run]

Find AMT Maestro Superset tasks in In Review, inspect their branches, merge
reviewed work into dev, validate, push origin/dev, sync active worktrees, and
mark tasks Done.

Options:
  --dry-run  Show what would land without merging, pushing, syncing, or updating tasks.
  --help     Show this help.
USAGE
}

dry_run=0
while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run)
      dry_run=1
      shift
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      echo "Unknown option: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

require_cmd() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "Missing required command: $1" >&2
    exit 1
  fi
}

trim() {
  local value="$1"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  printf '%s' "$value"
}

get_status_id() {
  local status_name="$1"
  printf '%s' "$statuses_json" | jq -r --arg name "$status_name" '.[] | select(.name == $name) | .id' | head -n 1
}

task_branch() {
  local task_text="$1"
  printf '%s\n' "$task_text" | awk '
    /^Branch:/ {
      value = $0
      sub(/^Branch:[[:space:]]*/, "", value)
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", value)
      if (value != "" && value != "—" && value != "-") {
        print value
        exit
      }
    }
  '
}

branch_worktree_path() {
  local branch="$1"
  git worktree list --porcelain | awk -v target="refs/heads/${branch}" '
    /^worktree / { worktree = $2 }
    /^branch / {
      if ($2 == target) {
        print worktree
        exit
      }
    }
  '
}

sync_worktrees() {
  git worktree list --porcelain | awk '
    /^worktree / { worktree = $2 }
    /^branch / {
      branch = $2
      sub(/^refs\/heads\//, "", branch)
      if (branch != "dev") {
        print worktree "\t" branch
      }
    }
  ' | while IFS=$'\t' read -r worktree branch; do
    if [[ -n "$(git -C "$worktree" status --porcelain)" ]]; then
      echo "Skipping dirty worktree: ${branch} (${worktree})"
      continue
    fi

    echo "Syncing ${branch} with dev"
    git -C "$worktree" merge --ff-only dev
  done
}

require_cmd git
require_cmd jq
require_cmd npm
require_cmd superset

current_branch="$(git branch --show-current)"
if [[ "$current_branch" != "dev" ]]; then
  echo "Run this from the dev checkout. Current branch: ${current_branch}" >&2
  exit 1
fi

if [[ -n "$(git status --porcelain)" ]]; then
  echo "dev has uncommitted changes. Commit or stash them before landing reviewed work." >&2
  git status --short >&2
  exit 1
fi

echo "Updating dev from origin/dev"
git pull --ff-only origin dev

statuses_json="$(superset tasks statuses list --json)"
in_review_id="$(get_status_id "In Review")"
done_id="$(get_status_id "Done")"

if [[ -z "$in_review_id" || -z "$done_id" ]]; then
  echo "Could not resolve Superset status IDs for In Review/Done." >&2
  exit 1
fi

mapfile -t tasks < <(
  superset tasks list --status "$in_review_id" --search "AMT Maestro" --limit 100 |
    awk 'NR > 1 && $1 != "" && $1 != "No" { print $1 }'
)

if [[ "${#tasks[@]}" -eq 0 ]]; then
  echo "No AMT Maestro tasks in In Review."
  exit 0
fi

start_sha="$(git rev-parse HEAD)"
merged_tasks=()
no_change_tasks=()
skipped=0

for task in "${tasks[@]}"; do
  echo
  echo "Reviewing task: ${task}"
  task_text="$(superset tasks get "$task")"
  branch="$(task_branch "$task_text")"
  branch="$(trim "$branch")"

  if [[ -z "$branch" ]]; then
    echo "  Skipping: could not find a Branch: value in the task description." >&2
    skipped=1
    continue
  fi

  if ! git show-ref --verify --quiet "refs/heads/${branch}"; then
    echo "  Skipping: local branch does not exist: ${branch}" >&2
    skipped=1
    continue
  fi

  worktree_path="$(branch_worktree_path "$branch")"
  if [[ -n "$worktree_path" && -n "$(git -C "$worktree_path" status --porcelain)" ]]; then
    echo "  Skipping: worktree has uncommitted changes: ${worktree_path}" >&2
    skipped=1
    continue
  fi

  read -r dev_only branch_only < <(git rev-list --left-right --count "dev...${branch}")
  echo "  Branch: ${branch}"
  echo "  dev-only commits: ${dev_only}"
  echo "  branch-only commits: ${branch_only}"

  if [[ "$branch_only" == "0" ]]; then
    echo "  No unique commits to merge."
    no_change_tasks+=("$task")
    continue
  fi

  echo "  Commits:"
  git log --oneline "dev..${branch}" | sed 's/^/    /'

  echo "  Diff stat:"
  git diff --stat "dev...${branch}" | sed 's/^/    /'

  if [[ "$dry_run" == "1" ]]; then
    continue
  fi

  merge_slug="${branch##*/}"
  git merge --no-ff "$branch" -m "Merge ${merge_slug} worktree updates into dev"
  merged_tasks+=("$task")
done

if [[ "$dry_run" == "1" ]]; then
  echo
  echo "Dry run complete. No merges, pushes, syncs, or task updates were made."
  exit "$skipped"
fi

if [[ "${#merged_tasks[@]}" -gt 0 ]]; then
  echo
  echo "Validating merged changes"
  changed_php="$(git diff --name-only "$start_sha..HEAD" -- '*.php' || true)"
  if [[ -n "$changed_php" ]]; then
    while IFS= read -r file; do
      [[ -f "$file" ]] || continue
      php -l "$file"
    done <<< "$changed_php"
  fi

  npm run build

  echo
  echo "Pushing dev"
  git push origin dev

  echo
  echo "Syncing active worktrees"
  sync_worktrees
fi

for task in "${merged_tasks[@]}" "${no_change_tasks[@]}"; do
  echo "Marking Done: ${task}"
  superset tasks update "$task" --status-id "$done_id"
done

if [[ "$skipped" != "0" ]]; then
  echo "Some tasks were skipped. See messages above." >&2
  exit 1
fi

echo
echo "Maestro land reviewed complete."
