{
  "name": "standard-press",
  "taxonomy": {
    "client": "standard",
    "project": "standard-press"
  },
  "baseBranch": "dev",
  "taskPrefix": "Admiral",
  "setupCommand": "npm ci --prefer-offline --no-audit --no-fund",
  "statuses": {
    "todo": "Staged",
    "inProgress": "Processing",
    "blocked": "Blocked",
    "inReview": "Reviewing",
    "verifying": "Verifying",
    "done": "Done",
    "canceled": "Canceled"
  },
  "workflow": {
    "mode": "review",
    "landing": "local",
    "acceptance": "Verifying",
    "ciCommand": "npm run build",
    "autoPush": false
  },
  "labels": {
    "required": [
      "admiral",
      "client:<client>",
      "project:<project>",
      "type:<work-type>",
      "area:<area>",
      "agent:<agent>",
      "risk:<low|medium|high>"
    ]
  },
  "policy": {
    "forbiddenPaths": [
      ".env",
      ".env.*"
    ],
    "requireReservationsForChangedFiles": false
  },
  "agentPreflight": {
    "commands": {},
    "cacheTtlHours": 24
  },
  "router": {
    "typeDefaults": {
      "feature": "implementer",
      "bugfix": "implementer",
      "refactor": "implementer",
      "backend": "implementer",
      "ui": "implementer",
      "chore": "implementer",
      "docs": "docs",
      "copy": "marketer",
      "research": "scout",
      "test": "verifier"
    },
    "seats": {
      "orchestrator": {
        "command": "claude --model fable --effort high --dangerously-skip-permissions",
        "fallback": [
          "claude --model opus --effort xhigh --dangerously-skip-permissions",
          "codex -m gpt-5.5 -c model_reasoning_effort=xhigh --dangerously-bypass-approvals-and-sandbox"
        ]
      },
      "scout": {
        "command": "grok -m grok-composer-2.5-fast",
        "fallback": [
          "codex -m gpt-5.5 -c model_reasoning_effort=xhigh --dangerously-bypass-approvals-and-sandbox",
          "claude --model opus --effort xhigh --dangerously-skip-permissions"
        ]
      },
      "implementer": {
        "command": "codex -m gpt-5.5 -c model_reasoning_effort=xhigh --dangerously-bypass-approvals-and-sandbox",
        "fallback": [
          "claude --model opus --effort xhigh --dangerously-skip-permissions",
          "grok -m grok-composer-2.5-fast"
        ]
      },
      "verifier": {
        "command": "opencode run -m zhipuai-coding-plan/glm-5.2 \"<prompt>\"",
        "fallback": [
          "codex -m gpt-5.5 -c model_reasoning_effort=xhigh --dangerously-bypass-approvals-and-sandbox",
          "claude --model opus --effort xhigh --dangerously-skip-permissions"
        ]
      },
      "reviewer": {
        "command": "claude --model opus --effort xhigh --dangerously-skip-permissions",
        "fallback": [
          "codex -m gpt-5.5 -c model_reasoning_effort=xhigh --dangerously-bypass-approvals-and-sandbox"
        ]
      },
      "marketer": {
        "command": "grok -m grok-build",
        "fallback": [
          "claude --model opus --effort xhigh --dangerously-skip-permissions"
        ]
      },
      "docs": {
        "command": "claude --agent docs-writer --model opus --effort xhigh --dangerously-skip-permissions",
        "fallback": [
          "claude --model opus --effort xhigh --dangerously-skip-permissions",
          "codex -m gpt-5.5 -c model_reasoning_effort=xhigh --dangerously-bypass-approvals-and-sandbox"
        ]
      }
    }
  },
  "validationCommand": "npm run build",
  "coordinationState": {
    "gitCommonDir": "admiral",
    "fallbackDir": ".admiral"
  },
  "localState": [
    ".admiral/mainline-queue.json",
    ".admiral/reservations.json",
    ".admiral/messages.jsonl",
    ".admiral/events.jsonl",
    ".admiral/report-cursors.json",
    ".admiral/agent-preflight.json",
    ".admiral/active.md",
    ".admiral/archive.md"
  ],
  "github": {
    "project": {
      "number": 10,
      "owner": "joelgrodriguez"
    }
  }
}