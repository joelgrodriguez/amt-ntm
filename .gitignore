# Worktrees
.worktrees/

# Content inventory scratch space (generated workbook + extractor)
docs/content-inventory/

# Content-review exports are generated by `npm run content:export` / `:xlsx` —
# regenerate, don't commit. The scripts + manifest in scripts/content/ ARE tracked.
scripts/content/exports/*.csv
scripts/content/exports/*.xlsx

# Maestro orchestrator state — see .maestro/.gitignore for per-file rules
# (README is tracked; active.md / archive.md stay local)

# Impeccable design-tooling scratch (critique snapshots, ignore lists)
.impeccable/

# Dependencies
node_modules/

# Environment
.env.local

# IDE
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Build output
app/dist/

# Generated files
app/resources/css/theme-vars.css
app/.vite-dev-server

# Reference assets (large images/PDFs for design reference only)
docs/references/
docs/*.pdf
docs/*.png

# Brainstorm sessions
.superpowers/

# Office temp/lock files
.~lock.*#
~$*

# Local dev tools
solo.yml
paseo.json
.conductor/

# Local-only planning docs
docs/feedback/e_sola/
docs/*.docx
docs/*.xlsx
docs/superpowers/
docs/content-needs-*.md
docs/meeting-*.md
docs/page-outlines-*.md
