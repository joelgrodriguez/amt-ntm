{
  "name": "standard-press",
  "taxonomy": {
    "client": "new-tech",
    "project": "ntm-wp"
  },
  "baseBranch": "dev",
  "taskPrefix": "Shogun",
  "setupCommand": "npm ci --prefer-offline --no-audit --no-fund",
  "tasks": {
    "backend": "github-issues"
  },
  "statuses": {
    "todo": "Staged",
    "inProgress": "Processing",
    "inReview": "Reviewing",
    "verifying": "Verifying",
    "done": "Done",
    "canceled": "Canceled"
  },
  "workflow": {
    "mode": "review",
    "landing": "local",
    "acceptance": "Verifying",
    "ciCommand": "npm run build",
    "autoPush": false
  },
  "labels": {
    "required": [
      "shogun",
      "project:<slug>",
      "branch:<branch>",
      "type:<work-type>",
      "area:<area>",
      "agent:<agent>",
      "risk:<low|medium|high>"
    ]
  },
  "policy": {
    "forbiddenPaths": [
      ".env",
      ".env.*"
    ],
    "requireReservationsForChangedFiles": false
  },
  "agentPreflight": {
    "commands": {},
    "cacheTtlHours": 24
  },
  "validationCommand": "npm run build",
  "coordinationState": {
    "gitCommonDir": "shogun",
    "fallbackDir": ".shogun"
  },
  "localState": [
    ".shogun/mainline-queue.json",
    ".shogun/reservations.json",
    ".shogun/messages.jsonl",
    ".shogun/events.jsonl",
    ".shogun/report-cursors.json",
    ".shogun/agent-preflight.json",
    ".shogun/active.md",
    ".shogun/archive.md",
    ".shogun/graph.json"
  ],
  "branchPrefix": "shogun",
  "github": {
    "repo": "joelgrodriguez/amt-ntm"
  }
}
